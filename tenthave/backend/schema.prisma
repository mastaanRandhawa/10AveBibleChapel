generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  ADMIN     // Full access - can update calendar and announcements
  MEMBER    // Regular member access
  GUEST     // Limited access
}

enum PrayerCategory {
  HEALTH
  FAMILY
  WORK
  SPIRITUAL
  COMMUNITY
  OTHER
}

enum PrayerPriority {
  URGENT
  HIGH
  NORMAL
}

enum PrayerStatus {
  PENDING     // Awaiting approval
  APPROVED    // Visible to authorized users
  REJECTED    // Not approved for display
  ANSWERED    // Prayer has been answered
}

enum ContentStatus {
  DRAFT       // Not yet published
  PUBLISHED   // Live on website
  ARCHIVED    // No longer active
}

// ============================================================================
// USER MANAGEMENT
// ============================================================================

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  name              String
  role              UserRole  @default(MEMBER)
  
  // Account status
  isActive          Boolean   @default(true)
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([email])
  @@index([role])
  @@map("users")
}

// ============================================================================
// CALENDAR & EVENTS
// ============================================================================

model CalendarEvent {
  id          String        @id @default(cuid())
  title       String
  description String?
  
  // Event timing
  startDate   DateTime
  endDate     DateTime?
  isAllDay    Boolean       @default(false)
  recurrence  String?       // "daily", "weekly", "monthly", "yearly", or null for one-time events
  
  // Event details
  location    String?
  category    String?       // "service", "ministry", "special", "meeting", etc.
  color       String?       // Hex color for calendar display
  
  // Visibility and status
  status      ContentStatus @default(PUBLISHED)
  isPublic    Boolean       @default(true)
  
  // Optional links and attachments
  link        String?       // External link (e.g., Zoom, registration)
  image       String?       // Event image path
  
  // Timestamps
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([startDate])
  @@index([status])
  @@index([isPublic])
  @@map("calendar_events")
}

// ============================================================================
// ANNOUNCEMENTS
// ============================================================================

model Announcement {
  id          String        @id @default(cuid())
  title       String
  content     String        @db.Text // HTML or markdown content
  
  // Announcement details
  category    String?       // "general", "ministry", "event", "prayer", etc.
  priority    String?       // "high", "normal", "low"
  
  // Visibility and scheduling
  status      ContentStatus @default(PUBLISHED)
  isPublic    Boolean       @default(true)
  startDate   DateTime?     // When to start showing
  endDate     DateTime?     // When to stop showing
  
  // Optional attachments
  image       String?       // Announcement image path
  link        String?       // Related link
  
  // Timestamps
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([status])
  @@index([isPublic])
  @@index([startDate])
  @@index([endDate])
  @@index([createdAt])
  @@map("announcements")
}

// ============================================================================
// PRAYER REQUEST SYSTEM
// ============================================================================

model PrayerRequest {
  id          String          @id @default(cuid())
  title       String
  description String
  requester   String?         // Optional name, can be anonymous
  
  // Classification
  category    PrayerCategory  @default(OTHER)
  priority    PrayerPriority  @default(NORMAL)
  status      PrayerStatus    @default(PENDING)
  isPrivate   Boolean         @default(false)
  
  // Response tracking
  isAnswered  Boolean         @default(false)
  answeredAt  DateTime?
  answerNotes String?         // Admin notes about the answer
  
  // Timestamps
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  @@index([status])
  @@index([category])
  @@index([isPrivate])
  @@index([createdAt])
  @@map("prayer_requests")
}

// ============================================================================
// SERMONS
// ============================================================================

model Sermon {
  id          String        @id @default(cuid())
  title       String
  description String?       @db.Text
  
  // Sermon details
  speaker     String
  date        DateTime
  passage     String?       // Bible passage reference
  series      String?       // Sermon series name
  
  // Media links
  videoUrl    String?       // YouTube, Vimeo, etc.
  audioUrl    String?       // Direct audio file or streaming link
  thumbnail   String?       // Image/thumbnail URL
  
  // Visibility and status
  status      ContentStatus @default(PUBLISHED)
  isPublic    Boolean       @default(true)
  isFeatured  Boolean       @default(false)
  
  // Timestamps
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([status])
  @@index([isPublic])
  @@index([isFeatured])
  @@index([date])
  @@index([series])
  @@map("sermons")
}
